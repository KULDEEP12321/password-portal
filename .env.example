# ============================================================================
# Password Portal — environment configuration (EXAMPLE)
# Copy to `.env` and fill in. NEVER commit a real `.env` (it is git-ignored).
# ============================================================================

APP_NAME=Vault

# --- Encryption: AES-256-GCM master key. Exactly 32 bytes, base64-encoded. ---
# Generate:  openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# --- Session sealing key. Encrypts/signs the session cookie. Min 32 chars. ---
# Generate:  openssl rand -hex 32
SESSION_PASSWORD=
SESSION_COOKIE_NAME=pp_session
SESSION_MAX_AGE_SEC=28800
# Secure by default. Set to false ONLY for local http dev.
COOKIE_SECURE=true
# Trust X-Forwarded-For for the client IP (used by rate limiting + audit).
# Enable ONLY behind a proxy you control that sets it. Default false = socket IP.
TRUST_PROXY=false

# --- Initial admin. Created automatically on first run if no users exist. ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# --- Storage driver: "r2" (production) or "local" (dev filesystem fallback) ---
# Leave unset to auto-select: r2 when R2_* are configured, otherwise local.
# STORAGE_DRIVER=r2
LOCAL_STORAGE_DIR=.data

# --- Cloudflare R2 (S3-compatible). Required when STORAGE_DRIVER=r2. ---
# Either set R2_ACCOUNT_ID (endpoint is derived) or set R2_ENDPOINT explicitly.
R2_ACCOUNT_ID=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
